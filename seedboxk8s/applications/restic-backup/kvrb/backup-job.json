{
  "apiVersion": "batch/v1",
  "kind": "Job",
  "metadata": {
    "name": "$JOB_NAME",
    "namespace": "$NAMESPACE",
    "labels": {
      "app.kubernetes.io/name": "kvrb",
      "app.kubernetes.io/component": "volume-backup"
    },
    "annotations": {
      "kvrb.seedboxk8s.micahrl.com/pvc-namespace": "$NAMESPACE",
      "kvrb.seedboxk8s.micahrl.com/pvc-name": "$PVC_NAME"
    }
  },
  "spec": {
    "backoffLimit": 0,
    "template": {
      "metadata": {
        "labels": {
          "app.kubernetes.io/name": "kvrb",
          "app.kubernetes.io/component": "volume-backup"
        },
        "annotations": {
          "kvrb.seedboxk8s.micahrl.com/pvc-namespace": "$NAMESPACE",
          "kvrb.seedboxk8s.micahrl.com/pvc-name": "$PVC_NAME"
        }
      },
      "spec": {
        "restartPolicy": "Never",
        "containers": [
          {
            "name": "restic",
            "image": "alpine:3.22",
            "imagePullPolicy": "IfNotPresent",
            "envFrom": [
              {
                "secretRef": {
                  "name": "$SECRET_NAME"
                }
              }
            ],
            "command": ["/bin/sh", "-ceu"],
            "args": [
              "apk add --no-cache ca-certificates restic\nrestic version\necho 'Checking restic repository'\nrestic snapshots || { echo 'Initializing restic repository'; restic init; }\nexclude_args=''\nif test -n \"$${RESTIC_EXCLUDES:-}\"; then\n  printf '%s\\n' \"$${RESTIC_EXCLUDES}\" > /tmp/restic-excludes\n  echo 'Using restic exclude file:'\n  cat /tmp/restic-excludes\n  exclude_args='--exclude-file /tmp/restic-excludes'\nfi\necho 'Backing up $SOURCE_MOUNT'\nrestic backup $SOURCE_MOUNT $${exclude_args} --host seedboxk8s --tag namespace=$${POD_NAMESPACE} --tag pvc=$PVC_NAME --verbose\necho 'Applying restic retention policy'\nrestic forget --keep-daily 14 --keep-weekly 8 --keep-monthly 120 --prune"
            ],
            "env": [
              {
                "name": "POD_NAMESPACE",
                "valueFrom": {
                  "fieldRef": {
                    "fieldPath": "metadata.namespace"
                  }
                }
              }
            ],
            "volumeMounts": [
              {
                "name": "source",
                "mountPath": "$SOURCE_MOUNT",
                "readOnly": true
              }
            ]
          }
        ],
        "volumes": [
          {
            "name": "source",
            "persistentVolumeClaim": {
              "claimName": "$PVC_NAME",
              "readOnly": true
            }
          }
        ]
      }
    }
  }
}

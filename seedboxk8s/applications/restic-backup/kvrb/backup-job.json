{
  "apiVersion": "batch/v1",
  "kind": "Job",
  "metadata": {
    "name": "$JOB_NAME",
    "namespace": "$NAMESPACE"
  },
  "spec": {
    "backoffLimit": 0,
    "template": {
      "spec": {
        "restartPolicy": "Never",
        "containers": [
          {
            "name": "restic",
            "image": "alpine:3.22",
            "imagePullPolicy": "IfNotPresent",
            "envFrom": [
              {
                "secretRef": {
                  "name": "$SECRET_NAME"
                }
              }
            ],
            "command": ["/bin/sh", "-ceu"],
            "args": [
              "apk add --no-cache ca-certificates restic\nrestic version\necho 'Checking restic repository'\nrestic snapshots || { echo 'Initializing restic repository'; restic init; }\necho 'Backing up $SOURCE_MOUNT'\nrestic backup $SOURCE_MOUNT --host seedboxk8s --tag namespace=$${POD_NAMESPACE} --tag pvc=$PVC_NAME --verbose\necho 'Applying restic retention policy'\nrestic forget --keep-daily 14 --keep-weekly 8 --keep-monthly 120 --prune"
            ],
            "env": [
              {
                "name": "POD_NAMESPACE",
                "valueFrom": {
                  "fieldRef": {
                    "fieldPath": "metadata.namespace"
                  }
                }
              }
            ],
            "volumeMounts": [
              {
                "name": "source",
                "mountPath": "$SOURCE_MOUNT",
                "readOnly": true
              }
            ]
          }
        ],
        "volumes": [
          {
            "name": "source",
            "persistentVolumeClaim": {
              "claimName": "$PVC_NAME",
              "readOnly": true
            }
          }
        ]
      }
    }
  }
}

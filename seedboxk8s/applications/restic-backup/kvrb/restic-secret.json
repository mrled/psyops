{
  "apiVersion": "v1",
  "kind": "Secret",
  "metadata": {
    "name": "$NAME",
    "namespace": "$NAMESPACE"
  },
  "type": "Opaque",
  "stringData": {
    "AWS_ACCESS_KEY_ID": "$AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY": "$AWS_SECRET_ACCESS_KEY",
    "RESTIC_PASSWORD": "$RESTIC_PASSWORD",
    "RESTIC_REPOSITORY": "$RESTIC_REPOSITORY"
  }
}


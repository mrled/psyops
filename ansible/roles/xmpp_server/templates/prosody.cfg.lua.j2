-- Prosody XMPP Server Configuration
-- Generated by Ansible
-- Federation enabled, MAM enabled

-- Plugin paths (for community modules)
plugin_paths = { "/var/lib/prosody/custom_plugins" }

-- Server-wide settings
admins = { "{{ xmpp_server_admin_user }}@{{ xmpp_server_domain }}" }

-- Enable better logging
log = {
    info = "/var/log/prosody/prosody.log";
    error = "/var/log/prosody/prosody.err";
}

-- Pidfile location (for prosodyctl)
pidfile = "/run/prosody/prosody.pid"

-- Network settings
c2s_ports = { {{ xmpp_server_c2s_port }} }
c2s_interfaces = { "::", "0.0.0.0" }

s2s_ports = { {{ xmpp_server_s2s_port }} }
s2s_interfaces = { "::", "0.0.0.0" }

-- Security settings
c2s_require_encryption = true

s2s_require_encryption = true
s2s_secure_auth = true

-- Use modern TLS options
ssl = {
    protocol = "tlsv1_2+";
    ciphers = "HIGH+kEDH:HIGH+kEECDH:HIGH:!PSK:!SRP:!3DES:!aNULL";
    dhparam = "{{ xmpp_server_ssl_dhparam }}";
}

-- Authentication
authentication = "internal_hashed"

-- Storage configuration
storage = "internal"

-- Enable module management
modules_enabled = {
    -- Core modules
    "roster";
    "saslauth";
    "tls";
    "dialback";      -- S2S dialback authentication
    "disco";
    "posix";
    "private";
    "vcard4";
    "vcard_legacy";

    -- Useful modules
    "version";
    "uptime";
    "time";
    "ping";
    "admin_adhoc";
    "admin_telnet";

    -- Privacy and sync
    "blocklist";
    "bookmarks";     -- XEP-0402 synchronized bookmarks across devices
    "carbons";       -- Multi-device sync (real-time)
    "smacks";        -- Stream management and resumption
    "csi_simple";    -- Client state indication
    "cloud_notify";  -- Push notifications

    -- HTTP modules
    "bosh";
    "websocket";
    "http_files";

    -- Other modules
    "announce";
    "watchregistrations";
    "pep";
    "register";
    "mam";           -- Message archive management

    -- Additional modules
    "lastactivity";              -- Show when users were last online
    "server_contact_info";       -- Publish admin contact info (XEP-0157)
    "s2s_bidi";                  -- Bidirectional S2S (more efficient federation)
}

-- Disable account registrations unless explicitly enabled
allow_registration = {{ xmpp_server_allow_registration | lower }}

-- HTTP file share settings
http_file_share_size_limit = {{ xmpp_server_http_upload_quota }}
http_file_share_expire_after = 60 * 60 * 24 * {{ xmpp_server_http_upload_expire_days }}

-- HTTP settings
http_ports = { {{ xmpp_server_http_port }} }
http_interfaces = { "::", "0.0.0.0" }

https_ports = { {{ xmpp_server_https_port }} }
https_interfaces = { "::", "0.0.0.0" }

-- Message archive settings
default_archive_policy = "always"  -- Archive all messages automatically
-- archive_expires_after = "4w"  -- Keep forever by default

-- Stream Management (XEP-0198) - Better mobile experience
smacks_hibernation_time = 600  -- Keep stream alive for 10 minutes after disconnect

-- Rate limiting
-- These don't affect HTTP file uploads, but would affect inline images and actual messages
limits = {
    --c2s = {
    --    rate = "10mb/s";
    --};
    s2sin = {
        rate = "10mb/s";
    };
}

-- Virtual host
-- This is the domain that appears in user JIDs (user@domain.com)
-- SRV records point this to the actual server hostname
VirtualHost "{{ xmpp_server_domain }}"
    enabled = true
    -- Tell HTTP modules and clients to use the server hostname for certificate validation
    http_host = "{{ xmpp_server_hostname }}"
    -- Certificate matches the server hostname (xmpp.micahrl.com), not the domain (micahrl.com)
    -- XMPP clients use SRV records to discover the server and validate against the SRV target
    ssl = {
        key = "{{ xmpp_server_ssl_key_dest }}";
        certificate = "{{ xmpp_server_ssl_cert_dest }}";
    }

-- Multi-user chat (MUC)
Component "conference.{{ xmpp_server_hostname }}" "muc"
    modules_enabled = {
        "muc_mam";   -- Message archive in MUC
        "vcard_muc"; -- Add vCard support to MUC
    }
    restrict_room_creation = "local"
    max_history_messages = 100

-- HTTP file share component
Component "upload.{{ xmpp_server_hostname }}" "http_file_share"

#!/usr/bin/env python3
# -*- mode: python -*-
"""
Gitea webhook receiver — triggers GitHub push when the protected default branch is updated.

Gitea must be configured to send a push webhook to:
  http://127.0.0.1:{{ chineseroom_gitea_webhook_port }}/push-sync

Set the webhook Secret to the value of chineseroom_gitea_webhook_secret.
"""
import hashlib
import hmac
import http.server
import json
import logging
import os
import subprocess

logging.basicConfig(level=logging.INFO, format='%(asctime)s %(levelname)s %(message)s')
log = logging.getLogger(__name__)

SECRET = os.environ['GITEA_WEBHOOK_SECRET'].encode()
PUSH_SCRIPT = os.environ['GITEA_PUSH_SCRIPT']
MIRRORS_DIR = os.environ['GITEA_MIRRORS_DIR']
HOST = os.environ.get('GITEA_WEBHOOK_LISTEN', '127.0.0.1')
PORT = int(os.environ.get('GITEA_WEBHOOK_PORT', '9420'))


class WebhookHandler(http.server.BaseHTTPRequestHandler):
    def do_POST(self):
        if self.path != '/push-sync':
            self.send_response(404)
            self.end_headers()
            return

        length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(length)

        # Validate HMAC-SHA256 signature from Gitea
        sig = self.headers.get('X-Gitea-Signature', '')
        expected = hmac.new(SECRET, body, hashlib.sha256).hexdigest()
        if not hmac.compare_digest(sig, expected):
            log.warning('Invalid webhook signature from %s', self.client_address[0])
            self.send_response(403)
            self.end_headers()
            return

        try:
            payload = json.loads(body)
        except json.JSONDecodeError:
            self.send_response(400)
            self.end_headers()
            return

        ref = payload.get('ref', '')
        repo_name = payload.get('repository', {}).get('name', '')
        log.info('Push event: repo=%s ref=%s', repo_name, ref)

        mirror_dir = os.path.join(MIRRORS_DIR, repo_name)
        auto_push_marker = os.path.join(mirror_dir, '.git', 'gitea', 'auto-push')
        branch_file = os.path.join(mirror_dir, '.git', 'gitea', 'default-branch')

        if not os.path.isdir(mirror_dir):
            self._reply(200, b'no mirror configured\n')
            return

        if not os.path.exists(auto_push_marker):
            self._reply(200, b'auto-push disabled\n')
            return

        if not os.path.exists(branch_file):
            log.warning('Missing .git/gitea/default-branch for %s', repo_name)
            self._reply(500, b'misconfigured: no default branch file\n')
            return

        with open(branch_file) as fh:
            default_branch = fh.read().strip()

        if ref != f'refs/heads/{default_branch}':
            log.info('Push to %s is not the default branch, skipping', ref)
            self._reply(200, b'not default branch\n')
            return

        log.info('Triggering GitHub push for %s:%s', repo_name, default_branch)
        subprocess.Popen(
            [PUSH_SCRIPT, repo_name, ref],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        self._reply(200, b'sync triggered\n')

    def _reply(self, code, body):
        self.send_response(code)
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, fmt, *args):
        log.debug('%s - %s', self.address_string(), fmt % args)


if __name__ == '__main__':
    server = http.server.HTTPServer((HOST, PORT), WebhookHandler)
    log.info('Listening on %s:%d', HOST, PORT)
    server.serve_forever()

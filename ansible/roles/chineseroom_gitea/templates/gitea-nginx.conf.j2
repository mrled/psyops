# Gitea reverse proxy — managed by Ansible role chineseroom_gitea

server {
    listen 80;
    server_name {{ chineseroom_gitea_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ chineseroom_gitea_domain }};

    ssl_certificate     {{ chineseroom_letsencrypt_base }}/live/{{ chineseroom_letsencrypt_domain }}/fullchain.pem;
    ssl_certificate_key {{ chineseroom_letsencrypt_base }}/live/{{ chineseroom_letsencrypt_domain }}/privkey.pem;

    # No body size limit — required for git-lfs uploads
    client_max_body_size 0;

    location / {
        proxy_pass http://127.0.0.1:{{ chineseroom_gitea_http_port }};

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support (git push over HTTP/2, Gitea live notifications)
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection $connection_upgrade;

        # Allow slow git operations over large repos
        proxy_read_timeout 300s;
    }
}

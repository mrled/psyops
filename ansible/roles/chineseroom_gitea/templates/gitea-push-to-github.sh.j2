#!/usr/bin/env bash
# -*- mode: bash -*-
# Push a branch from Gitea to the corresponding branch on GitHub.
# Called asynchronously by the webhook receiver when Gitea signals a push to
# refs/heads/<branch>.  The branch name is pushed verbatim to GitHub.
#
# Usage: push-to-github.sh <repo_name> <ref>
#   repo_name  Gitea repository name (must have a working clone in {{ chineseroom_gitea_mirrors_dir }})
#   ref        Git ref that was pushed, e.g. refs/heads/main
set -euo pipefail

REPO="${1:?usage: $0 <repo_name> <ref>}"
REF="${2:?usage: $0 <repo_name> <ref>}"
MIRRORS_DIR="{{ chineseroom_gitea_mirrors_dir }}"
MIRROR_DIR="$MIRRORS_DIR/$REPO"
LOCK_FILE="/tmp/gitea-push-${REPO}.lock"
LOG_TAG="gitea-push-github[$REPO]"

log() { logger -t "$LOG_TAG" -- "$*"; }

HEADS_PREFIX="refs/heads/"
if [[ "$REF" != ${HEADS_PREFIX}* ]]; then
    log "Ref $REF is not a branch; skipping"
    exit 0
fi

BRANCH="${REF#${HEADS_PREFIX}}"

if [[ ! -d "$MIRROR_DIR/.git" ]]; then
    log "Working clone not found: $MIRROR_DIR"
    exit 1
fi

# Prevent concurrent pushes for the same repo
exec 200>"$LOCK_FILE"
if ! flock -n 200; then
    log "Another push is already running for $REPO; skipping"
    exit 0
fi

(
    cd "$MIRROR_DIR"

    log "Fetching $BRANCH from Gitea..."
    git fetch origin "refs/heads/${BRANCH}:refs/remotes/origin/${BRANCH}"

    log "Fetching LFS objects from Gitea..."
    git lfs fetch origin --all || true

    log "Pushing $BRANCH to GitHub..."
    git push github "refs/remotes/origin/${BRANCH}:refs/heads/${BRANCH}"

    log "Pushing LFS objects to GitHub..."
    git lfs push github --all || true

    log "Push to GitHub complete."
)
